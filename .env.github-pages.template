# ============================================
# 🌐 GitHub Pages 部署环境变量
# ============================================
# 
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 根据实际情况修改以下值
# 3. 不要将包含真实密钥的文件提交到 Git！
#
# 部署位置: https://code.yyc3.top
# 构建工具: Vite + pnpm
# 托管平台: GitHub Pages (GitHub Actions)
# ============================================

# ---- 应用基础配置 ----
VITE_APP_TITLE=YYC³ AI Code - 智能代码平台
VITE_APP_DESCRIPTION=言启千行代码，语枢万物智能
VITE_APP_VERSION=2.0.0

# ---- API 配置（如需要）----
VITE_API_BASE_URL=https://api.yyc3.top
VITE_API_TIMEOUT=30000

# ---- 功能开关 ----
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PWA=true

# ---- 第三方服务（可选）----
# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry 错误追踪（可选）
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ---- 构建优化 ----
VITE_BUILD_MODE=production
VITE_ENABLE_SOURCE_MAPS=true

# ---- 自定义域名 ----
VITE_PUBLIC_URL=https://code.yyc3.top

# ---- 社交媒体链接 ----
VITE_GITHUB_REPO=https://github.com/YOUR_USERNAME/YYC3-Code-AI
VITE_DOCS_URL=https://code.yyc3.top/docs

# ---- 联系信息 ----
VITE_SUPPORT_EMAIL=support@yyc3.top
VITE_FEEDBACK_URL=https://github.com/YOUR_USERNAME/YYC3-Code-AI/issues

# ============================================
# ⚠️ 安全提醒
# ============================================
# 
# ❌ 绝对不要提交包含真实密钥的 .env 文件到 Git
# ✅ 使用 GitHub Secrets 存储敏感信息
# ✅ 定期轮换 API 密钥和 Token
#
# GitHub Secrets 设置路径:
# Settings → Secrets and variables → Actions
# → New repository secret
# ============================================
