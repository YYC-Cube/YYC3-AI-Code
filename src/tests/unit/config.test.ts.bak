import { describe, it, expect } from 'vitest';
import { API_CONFIG, CACHE_CONFIG, APP_CONFIG } from '../../app/config';

describe('config — 应用配置', () => {
  describe('API 配置测试', () => {
    it('TC-CONF-001: API_CONFIG 应该存在', () => {
      expect(API_CONFIG).toBeDefined();
    });

    it('TC-CONF-002: API_CONFIG 应该包含 primary 和备用端点', () => {
      expect(API_CONFIG).toHaveProperty('primary');
      expect(API_CONFIG).toHaveProperty('standby1');
      expect(API_CONFIG).toHaveProperty('standby2');
    });

    it('TC-CONF-003: API_CONFIG 应该包含 endpoints 方法', () => {
      expect(typeof API_CONFIG.endpoints).toBe('function');
    });
  });

  describe('缓存配置测试', () => {
    it('TC-CONF-010: CACHE_CONFIG 应该存在', () => {
      expect(CACHE_CONFIG).toBeDefined();
    });

    it('TC-CONF-011: CACHE_CONFIG 应该包含连接配置', () => {
      expect(CACHE_CONFIG).toHaveProperty('primary');
      expect(CACHE_CONFIG).toHaveProperty('replica');
      expect(CACHE_CONFIG).toHaveProperty('sentinel');
    });

    it('TC-CONF-012: CACHE_CONFIG 应该包含 TTL 设置', () => {
      expect(CACHE_CONFIG).toHaveProperty('ttl');
      expect(typeof CACHE_CONFIG.ttl).toBe('number');
    });
  });

  describe('APP 配置测试', () => {
    it('TC-CONF-020: APP_CONFIG 应该存在', () => {
      expect(APP_CONFIG).toBeDefined();
    });

    it('TC-CONF-021: APP_CONFIG 应该包含所有子配置', () => {
      expect(APP_CONFIG).toHaveProperty('api');
      expect(APP_CONFIG).toHaveProperty('cache');
      expect(APP_CONFIG).toHaveProperty('ai');
    });
  });
});
