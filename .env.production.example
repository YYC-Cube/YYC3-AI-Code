# YYC³ AI Production Environment Variables Configuration
# This is a template for production environment variables
# DO NOT commit actual secrets to version control

# Application
NODE_ENV=production
VITE_APP_NAME=YYC³ AI
VITE_APP_VERSION=3.0.0
VITE_APP_URL=https://your-production-url.com

# API Configuration
VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_TIMEOUT=30000
VITE_API_RETRIES=2

# Authentication (Set in GitHub Secrets)
# VITE_AUTH_TOKEN_KEY will be provided by authentication service
# VITE_AUTH_REFRESH_TOKEN_KEY will be provided by authentication service

# Collaboration Services
VITE_YJS_ROOM_NAME=yyc3-production
VITE_YJS_SIGNALING_SERVER=wss://yjs.your-domain.com

# P2P Configuration
VITE_P2P_STUN_SERVER_1=stun:stun.your-domain.com:19302
VITE_P2P_STUN_SERVER_2=stun:stun1.your-domain.com:19302
VITE_P2P_DATA_CHANNEL_NAME=yyc3-data

# Edge Compute
VITE_EDGE_COMPUTE_ENABLED=true
VITE_EDGE_MAX_WORKERS=4

# Performance Monitoring
VITE_PERFORMANCE_MONITORING_ENABLED=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1

# Analytics (Optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_MIXPANEL_TOKEN=your_token_here

# Feature Flags
VITE_FEATURE_AI_ASSISTANT=true
VITE_FEATURE_COLLABORATION=true
VITE_FEATURE_OFFLINE_MODE=true
VITE_FEATURE_EDGE_COMPUTE=true
VITE_FEATURE_PERFORMANCE_MONITOR=true

# Development (disabled in production)
VITE_DEV_TOOLS_ENABLED=false
VITE_DEV_LOGGING_ENABLED=false

# Production
VITE_PROD_ERROR_REPORTING_ENABLED=true
VITE_PROD_ANALYTICS_ENABLED=true

# CDN Configuration (if using CDN)
VITE_CDN_URL=https://cdn.your-domain.com

# Security
VITE_SECURITY_ENABLED=true
VITE_RATE_LIMIT_ENABLED=true
