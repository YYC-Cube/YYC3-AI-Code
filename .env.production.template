# YYC³ AI - Production Environment
# Copy this file to .env.production and fill in actual values
# DO NOT commit .env.production with real secrets!

# ── Application ──
NODE_ENV=production
VITE_APP_NAME=YYC³ AI Code
VITE_APP_URL=https://code.yyc3.top

# ── API Configuration (update with your actual API endpoints) ──
VITE_API_BASE_URL=https://api.code.yyc3.top
VITE_API_TIMEOUT=30000

# ── Authentication ──
VITE_AUTH_ISSUER=https://auth.yyc3.top
VITE_AUTH_CLIENT_ID=yyc3-ai-code
VITE_AUTH_REDIRECT_URI=https://code.yyc3.top/auth/callback

# ── Collaboration Services ──
VITE_YJS_ROOM_NAME=yyc3-production
VITE_YJS_SIGNALING_SERVER=wss://yjs.code.yyc3.top

# ── Feature Flags ──
VITE_FEATURE_AI_ASSISTANT=true
VITE_FEATURE_COLLABORATION=true
VITE_FEATURE_OFFLINE_MODE=true

# ── Performance ──
VITE_PERFORMANCE_MONITORING_ENABLED=true
VITE_EDGE_COMPUTE_ENABLED=false

# ── Security ──
VITE_SECURITY_ENABLED=true
VITE_DEV_TOOLS_ENABLED=false
